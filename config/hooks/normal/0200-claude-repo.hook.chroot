#!/bin/sh
# Sanctum OS — preseed Anthropic's apt signing key for Claude Desktop.
# The key is fetched at image build time and its fingerprint is pinned here;
# the build FAILS on any mismatch. The app itself is intentionally NOT
# installed into the image (Anthropic's terms grant no redistribution right);
# sanctum-provision.service fetches it on the first boot with network.
set -e

KEYRING=/usr/share/keyrings/claude-desktop-archive-keyring.asc
EXPECTED_FPR="31DDDE24DDFAB679F42D7BD2BAA929FF1A7ECACE"

curl -fsSLo "$KEYRING" https://downloads.claude.ai/claude-desktop/key.asc

ACTUAL_FPR=$(gpg --show-keys --with-colons "$KEYRING" | awk -F: '/^fpr:/ {print $10; exit}')
if [ "$ACTUAL_FPR" != "$EXPECTED_FPR" ]; then
    echo "FATAL: Anthropic signing key fingerprint mismatch!" >&2
    echo "  expected: $EXPECTED_FPR" >&2
    echo "  actual:   $ACTUAL_FPR" >&2
    exit 1
fi
chmod 0644 "$KEYRING"
echo "Anthropic apt key pinned OK ($ACTUAL_FPR)"
