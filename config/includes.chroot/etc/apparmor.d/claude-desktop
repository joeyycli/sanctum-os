# Sanctum OS — AppArmor confinement for Claude Desktop (official arm64 .deb).
# Paths verified against claude-desktop 1.22209.0:
#   app dir   /usr/lib/claude-desktop/  (Electron; setuid chrome-sandbox helper)
#   launcher  /usr/bin/claude-desktop -> ../lib/claude-desktop/claude-desktop
#   config    ~/.config/Claude/
#
# Design: enforce a perimeter around secrets (ssh/gpg keys, keyrings, other
# users' homes, system credentials) while leaving the app's machinery —
# including the Claude Code integrated terminal, which legitimately executes
# user commands — unrestricted *within* the user's session. Child processes
# spawned by the terminal run unconfined (they are the user's own commands);
# the profile's job is to bound what the app process itself can silently read.
# Validated at image build time by apparmor_parser -Q (see 0700 hook).

abi <abi/4.0>,

include <tunables/global>

profile claude-desktop /usr/lib/claude-desktop/claude-desktop flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>
  include <abstractions/fonts>
  include <abstractions/nameservice>
  include <abstractions/ssl_certs>
  include <abstractions/mesa>
  include <abstractions/wayland>
  include <abstractions/X>
  include <abstractions/audio>

  # Session IPC (portals, notifications, tray) — file perimeter still applies.
  dbus,
  unix,
  signal,
  ptrace (read) peer=claude-desktop,

  # Electron/Chromium machinery
  /usr/lib/claude-desktop/** r,
  /usr/lib/claude-desktop/claude-desktop rix,
  /usr/lib/claude-desktop/chrome_crashpad_handler rix,
  /usr/lib/claude-desktop/chrome-sandbox rCx -> sandbox,
  owner @{PROC}/@{pid}/** rw,
  @{PROC}/sys/kernel/yama/ptrace_scope r,
  @{PROC}/sys/fs/inotify/max_user_watches r,
  @{PROC}/sys/kernel/random/boot_id r,
  @{PROC}/vmstat r,
  @{PROC}/cpuinfo r,
  @{PROC}/meminfo r,
  /sys/devices/** r,
  /sys/kernel/mm/transparent_hugepage/enabled r,
  /dev/shm/** rwk,

  # Chromium sandbox uses user namespaces (kept enabled system-wide)
  userns,

  # Network: Anthropic endpoints and MCP servers
  network inet stream,
  network inet6 stream,
  network inet dgram,
  network inet6 dgram,
  network netlink raw,

  # The user's world — broad by design (Claude Code edits projects anywhere in
  # $HOME); the deny perimeter below always wins in AppArmor.
  owner @{HOME}/ r,
  owner @{HOME}/** rwk,
  owner /tmp/** rwk,
  owner /var/tmp/** rwk,
  owner /run/user/@{uid}/** rwk,

  # Claude Code integrated terminal: system binaries run as the user's own
  # commands, unconfined — identical trust to any terminal emulator.
  /{usr/,}bin/** rPUx,
  /{usr/,}sbin/** rPUx,
  /usr/local/bin/** rPUx,
  /opt/** rPUx,

  # Secret perimeter — silently unreadable by the app process itself.
  deny @{HOME}/.ssh/{,**} rw,
  deny @{HOME}/.gnupg/{,**} rw,
  deny @{HOME}/.pki/{,**} rw,
  deny @{HOME}/.mozilla/{,**} rw,
  deny @{HOME}/.var/app/{,**} rw,
  deny @{HOME}/.local/share/keyrings/{,**} rw,
  deny /etc/shadow* rw,
  deny /etc/gshadow* rw,
  deny /etc/ssh/ssh_host_* rw,
  deny /home/*/ r,
  deny /root/{,**} rw,
  deny /var/lib/sanctum/{,**} w,

  profile sandbox {
    include <abstractions/base>
    capability sys_admin,
    capability sys_chroot,
    capability setuid,
    capability setgid,
    /usr/lib/claude-desktop/chrome-sandbox mr,
    /usr/lib/claude-desktop/claude-desktop rPx -> claude-desktop,
    owner @{PROC}/@{pid}/** rw,
    /dev/null rw,
    signal,
    unix,
  }
}
