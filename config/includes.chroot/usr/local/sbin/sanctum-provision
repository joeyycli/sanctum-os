#!/bin/sh
# Sanctum OS first-boot provisioning.
# Installs Claude Desktop from Anthropic's official signed apt repository the
# first time the system has network. Anthropic's terms don't permit
# redistributing the .deb inside the ISO, so it is fetched — once — here.
# Safe to re-run; stamps /var/lib/sanctum/provisioned on success.
set -e

STAMP_DIR=/var/lib/sanctum
STAMP="$STAMP_DIR/provisioned"

[ -e "$STAMP" ] && exit 0
mkdir -p "$STAMP_DIR"

if dpkg -s claude-desktop >/dev/null 2>&1; then
    touch "$STAMP"
    exit 0
fi

# Full index refresh: apt must see the Debian archive too, or any dependency
# of claude-desktop not already in the image is unresolvable (the image ships
# with empty apt lists — this bit us in v1.0.0 with xdg-utils).
apt-get update

DEBIAN_FRONTEND=noninteractive apt-get install -y claude-desktop

touch "$STAMP"
echo "Claude Desktop provisioned."
